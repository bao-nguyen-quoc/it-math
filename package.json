{
  "name": "it-math",
  "version": "1.0.0",
  "description": "Applied Mathematics in Information Technology (For post-graduation course purpose)",
  "homepage": "https://github.com/bao-nguyen-quoc/it-math#readme",
  "bugs": {
    "url": "https://github.com/bao-nguyen-quoc/it-math/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bao-nguyen-quoc/it-math.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
